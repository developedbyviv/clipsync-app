{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "annotations": { "list": [], "grafana_dashboard": "1" },
  "description": "ClipSync AKS infrastructure — node resources, pod health, PVC, network I/O.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Node Resources", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Node CPU Usage %",
      "type": "timeseries",
      "targets": [{ "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Node Memory Usage %",
      "type": "timeseries",
      "targets": [{ "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 101, "title": "Pod Health", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {}, "overrides": [{ "matcher": { "id": "byName", "options": "Restarts" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } }] }] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": { "footer": { "enablePagination": true }, "showHeader": true },
      "title": "Pod Status — clipsync namespaces",
      "type": "table",
      "targets": [
        { "expr": "kube_pod_info{namespace=~\"clipsync-.*\"}", "format": "table", "instant": true, "refId": "A" },
        { "expr": "kube_pod_container_status_restarts_total{namespace=~\"clipsync-.*\"}", "format": "table", "instant": true, "refId": "B" }
      ],
      "transformations": [{ "id": "merge", "options": {} }, { "id": "organize", "options": { "renameByName": { "pod": "Pod", "namespace": "Namespace", "Value #B": "Restarts", "node": "Node" }, "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 4,
      "options": { "legend": { "calcs": [], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "title": "Kubernetes Warning Events (clipsync namespaces)",
      "type": "timeseries",
      "targets": [{ "expr": "count_over_time(kube_event_count{namespace=~\"clipsync-.*\",type=\"Warning\"}[5m])", "legendFormat": "{{name}} — {{reason}}", "refId": "A" }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }, "id": 102, "title": "Storage & Network", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 }] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 29 },
      "id": 5,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdMarkers": true },
      "title": "PVC Usage %",
      "type": "gauge",
      "targets": [{ "expr": "kubelet_volume_stats_used_bytes{namespace=~\"clipsync-.*\"} / kubelet_volume_stats_capacity_bytes{namespace=~\"clipsync-.*\"}", "legendFormat": "{{persistentvolumeclaim}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 29 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Network I/O per Pod",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by(pod) (rate(container_network_receive_bytes_total{namespace=~\"clipsync-.*\"}[5m]))", "legendFormat": "RX {{pod}}", "refId": "A" },
        { "expr": "sum by(pod) (rate(container_network_transmit_bytes_total{namespace=~\"clipsync-.*\"}[5m]))", "legendFormat": "TX {{pod}}", "refId": "B" }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["clipsync", "infrastructure"],
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "title": "ClipSync — Infrastructure",
  "uid": "cs-infr4-dash",
  "version": 1
}
