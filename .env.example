# ─────────────────────────────────────────────────────────────────────────────
# ClipSync — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=clipsync
POSTGRES_USER=clipsync_user
POSTGRES_PASSWORD=clipsync_pass

# Full connection string used by the API service  
# In Docker Compose the host is "postgres" (service name)
DATABASE_URL=postgresql://clipsync_user:clipsync_pass@postgres:5432/clipsync

# ── Redis ─────────────────────────────────────────────────────────────────────
# In Docker Compose the host is "redis" (service name)
REDIS_URL=redis://redis:6379

# ── API Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (legacy — prefer FRONTEND_URL)
CORS_ORIGIN=http://localhost:3000

# ── Auth — JWT ────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d

# ── Auth — Google OAuth ───────────────────────────────────────────────────────
# See apps/api/src/config/passport.js for full setup instructions.
# Leave blank to disable Google OAuth (email/password auth still works).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── Auth — Session ────────────────────────────────────────────────────────────
# Used transiently during the OAuth redirect flow only (not for app auth)
# Generate: openssl rand -base64 48
SESSION_SECRET=your-session-secret-min-32-chars-change-this

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used for CORS and OAuth redirects
FRONTEND_URL=http://localhost:3000

# These MUST be prefixed with NEXT_PUBLIC_ to be exposed to the browser
# Replace localhost with your local IP for cross-device testing
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
